# ====================== DIRECTORIES ======================
IDIR = include
ODIR = obj
LDIR = lib

# ====================== COMPILER AND FLAGS ======================
CC       = clang
CPPFLAGS = -I$(IDIR)
CFLAGS   = -Wall -Wextra -Werror -O2 -g
LDFLAGS  = -L$(LDIR)
LDLIBS   = -lm

# ====================== FILES ======================
_DEPS = hellomake.h
DEPS  = $(addprefix $(IDIR)/,$(_DEPS))

_SRC = hellomake.c hellofunc.c
OBJ  = $(addprefix $(ODIR)/,$(_SRC:.c=.o))

# ====================== RULES ======================
$(ODIR)/%.o: %.c $(DEPS)
	@mkdir -p $(ODIR)
	$(CC) $(CPPFLAGS) $(CFLAGS) -c -o $@ $< 

hellomake: $(OBJ)
	$(CC) -o $@ $^ $(LDFLAGS) $(LDLIBS)

# ====================== TARGETS ======================
clean:
	rm -rf $(ODIR)

.PHONY: clean


# 'addprefix' cola o prefixo na frente de cada palavra