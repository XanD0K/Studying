CC= clang
CFLAGS = -ferror-limit=1 -gdwarf-4 -ggdb3 -O0 -std=c11 -Wall -Werror -Wextra \
         -Wno-gnu-folding-constant -Wno-sign-compare ... (várias flags)

LDLIBS = -lcrypt -lcs50 -lm

EXE = foo

SRCS = foo.c bar.c
OBJS = $(SRCS:.c=.o)

$(EXE): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $(OBJS) $(LDLIBS)


# LDLIBS → external libraries
# EXE → executable
# SRCS → all .c files
# OBJS = $(SRCS:.c=.o) → transforms all .c into .o files
